OUTPUT_DIR="/Users/lilin/develop/workspace/cursor/vocabulary_mining/EnLearning"
DATE=""
WORD_COUNT=70
PHRASE_COUNT=50
# 启用网页阅读工具时，推荐模型如 qwen3-max-2026-01-23
MODEL="qwen3-max-2026-01-23"
